# Model API
# For Anthropic direct: use https://api.anthropic.com and API_FORMAT=anthropic
# For OpenRouter (or any OpenAI-compatible gateway): use API_FORMAT=openrouter
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_API_BASE=https://api.anthropic.com
MODEL=claude-sonnet-4-5-20250929
API_FORMAT=anthropic

# Notion (required for tasks that use the notion environment)
# See docs/credentials-setup.md §1 for how to mint these two integration tokens
# and share the two hub pages with both integrations.
NOTION_ADMIN_KEY=ntn_...
NOTION_AGENT_KEY=ntn_...
NOTION_SOURCE_PAGE=ClawMark Source Hub
NOTION_EVAL_PAGE=ClawMark Eval Hub
# Optional:
# NOTION_STATE_FILE=notion_state.json
NOTION_PLAYWRIGHT_HEADLESS=true

# Google Sheets / Drive (required for tasks that use the google_sheets environment)
# Generated by `uv run python scripts/google_auth.py`. See docs/credentials-setup.md §2.
# The OAuth client secret lives at configs/gcp-oauth.keys.json (one-time, local only).
# The refresh-token file lives at configs/google_credentials.json (auto-refreshed at runtime).
GOOGLE_CREDENTIALS_PATH=configs/google_credentials.json
